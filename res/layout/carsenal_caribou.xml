<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardElevation="4dp"
    app:cardCornerRadius="12dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textView1"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="10dp"
                android:text="@string/CaringCaribou"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/can_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_gravity="center_horizontal|center"
                android:gravity="center"
                android:text="@string/can_caribou_desc" />

            <View
                android:id="@+id/divider1"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:background="?android:attr/listDivider" />

            <LinearLayout
                android:id="@+id/linearLayout2"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="5dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/spinner_iface_card"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    app:strokeColor="@color/nh_box_stroke_iface"
                    app:strokeWidth="2dp"
                    app:boxStrokeWidthFocused="3dp"
                    android:padding="4dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <Spinner
                        android:id="@+id/device_interface"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:spinnerMode="dropdown"/>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    app:strokeColor="@color/nh_box_stroke_iface"
                    app:strokeWidth="2dp"
                    app:boxStrokeWidthFocused="3dp"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageButton
                        android:id="@+id/refreshUSB"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_action_refresh"
                        android:contentDescription="@string/Refresh"
                        android:background="?attr/selectableItemBackgroundBorderless" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/caribou_advanced_options_card"
                android:layout_marginTop="10dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/ifc_box_stroke"
                app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="15dp">

                <TextView
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Settings"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:baselineAligned="false"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/message_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:strokeWidth="2dp"
                        app:boxStrokeWidthFocused="3dp"
                        app:boxStrokeColor="@color/ifc_box_stroke"
                        app:boxBackgroundColor="@color/transparent"
                        app:hintTextColor="@color/ifc_hint_text"
                        android:hint="@string/Message">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/caribou_message"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:text="@string/MessageValue"
                            android:textColor="@color/white"/>

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <!-- file_container row -->
                <LinearLayout
                    android:id="@+id/file_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="10dp"
                        android:hint="@string/File"
                        app:strokeWidth="2dp"
                        app:boxStrokeWidthFocused="3dp"
                        app:boxStrokeColor="@color/ifc_box_stroke"
                        app:boxBackgroundColor="@color/transparent"
                        app:hintTextColor="@color/ifc_hint_text">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/caribou_file"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:text="@string/CanLogPath"
                            android:textColor="@color/white" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <ImageButton
                        android:id="@+id/cariboufilebrowse"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/baseline_folder_open_24"
                        android:contentDescription="Browse"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="8dp"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/button_row4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/loop_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="4dp"
                        android:padding="8dp">

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/btn_toggle_loop"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/Loop"
                            android:textColor="@android:color/holo_red_light"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:paddingStart="12dp"
                            android:gravity="center_vertical"
                            tools:ignore="RtlSymmetry" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/reverse_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="4dp"
                        android:padding="8dp">

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/btn_toggle_reverse"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/Reverse"
                            android:textColor="@android:color/holo_red_light"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:paddingStart="12dp"
                            android:gravity="center_vertical"
                            tools:ignore="RtlSymmetry" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/pad_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="4dp"
                        android:padding="8dp">

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/btn_toggle_pad"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/Pad"
                            android:textColor="@android:color/holo_red_light"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:paddingStart="12dp"
                            android:gravity="center_vertical"
                            tools:ignore="RtlSymmetry" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/button_row6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:gravity="center">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/candump_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="4dp"
                        android:padding="8dp">

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/btn_toggle_candump"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/CandumpFormat"
                            android:textColor="@android:color/holo_red_light"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:paddingStart="12dp"
                            android:gravity="center_vertical"
                            tools:ignore="RtlSymmetry" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/button_row7"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:gravity="center">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/output_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="4dp"
                        android:padding="8dp">

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/btn_toggle_output"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/Output"
                            android:textColor="@android:color/holo_red_light"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:paddingStart="12dp"
                            android:gravity="center_vertical"
                            tools:ignore="RtlSymmetry" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>


                <LinearLayout
                    android:id="@+id/advanced_row_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="5dp"
                    android:baselineAligned="false">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/start_addr_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:strokeWidth="2dp"
                        app:boxStrokeWidthFocused="3dp"
                        app:boxStrokeColor="@color/ifc_box_stroke"
                        app:boxBackgroundColor="@color/transparent"
                        app:hintTextColor="@color/ifc_hint_text"
                        android:hint="@string/StartAddress">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/start_addr_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:text="@string/StartAddressValue"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:textColor="@color/white" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/length_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="3dp"
                        app:strokeWidth="2dp"
                        app:boxStrokeWidthFocused="3dp"
                        app:boxStrokeColor="@color/ifc_box_stroke"
                        app:boxBackgroundColor="@color/transparent"
                        app:hintTextColor="@color/ifc_hint_text"
                        android:hint="@string/Length">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/length_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:text="@string/LengthValue"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:textColor="@color/white" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/separate_line_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="3dp"
                        app:strokeWidth="2dp"
                        app:boxStrokeWidthFocused="3dp"
                        app:boxStrokeColor="@color/ifc_box_stroke"
                        app:boxBackgroundColor="@color/transparent"
                        app:hintTextColor="@color/ifc_hint_text"
                        android:hint="@string/SeparateLine">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/separate_line_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="@string/SeparateLineValue"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:textColor="@color/white" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/advanced_row_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="5dp"
                    android:baselineAligned="false">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/seed_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:strokeWidth="2dp"
                        app:boxStrokeWidthFocused="3dp"
                        app:boxStrokeColor="@color/ifc_box_stroke"
                        app:boxBackgroundColor="@color/transparent"
                        app:hintTextColor="@color/ifc_hint_text"
                        android:hint="@string/Seed">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/seed_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:text="@string/SeedValue"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:textColor="@color/white" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/id_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="3dp"
                        app:strokeWidth="2dp"
                        app:boxStrokeWidthFocused="3dp"
                        app:boxStrokeColor="@color/ifc_box_stroke"
                        app:boxBackgroundColor="@color/transparent"
                        app:hintTextColor="@color/ifc_hint_text"
                        android:hint="@string/ID">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/id_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:text="@string/IDValue"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:textColor="@color/white" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/src_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="3dp"
                        app:strokeWidth="2dp"
                        app:boxStrokeWidthFocused="3dp"
                        app:boxStrokeColor="@color/ifc_box_stroke"
                        app:boxBackgroundColor="@color/transparent"
                        app:hintTextColor="@color/ifc_hint_text"
                        android:hint="@string/Src">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/src_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:text="@string/SrcValue"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:textColor="@color/white" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/dst_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="3dp"
                        app:strokeWidth="2dp"
                        app:boxStrokeWidthFocused="3dp"
                        app:boxStrokeColor="@color/ifc_box_stroke"
                        app:boxBackgroundColor="@color/transparent"
                        app:hintTextColor="@color/ifc_hint_text"
                        android:hint="@string/Dst">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/dst_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:text="@string/DstValue"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:textColor="@color/white" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/advanced_row_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/min_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:strokeWidth="2dp"
                        app:boxStrokeWidthFocused="3dp"
                        app:boxStrokeColor="@color/ifc_box_stroke"
                        app:boxBackgroundColor="@color/transparent"
                        app:hintTextColor="@color/ifc_hint_text"
                        android:hint="@string/Minimum">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/min_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="@string/MinimumValue"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:textColor="@color/white" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/max_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="3dp"
                        app:strokeWidth="2dp"
                        app:boxStrokeWidthFocused="3dp"
                        app:boxStrokeColor="@color/ifc_box_stroke"
                        app:boxBackgroundColor="@color/transparent"
                        app:hintTextColor="@color/ifc_hint_text"
                        android:hint="@string/Maximum">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/max_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="@string/MaximumValue"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:textColor="@color/white" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/delay_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="3dp"
                        app:strokeWidth="2dp"
                        app:boxStrokeWidthFocused="3dp"
                        app:boxStrokeColor="@color/ifc_box_stroke"
                        app:boxBackgroundColor="@color/transparent"
                        app:hintTextColor="@color/ifc_hint_text"
                        android:hint="@string/Delay">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/delay_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="@string/DelayValue"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:textColor="@color/white" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

            </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:id="@+id/divider3"
                android:layout_width="match_parent"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="5dp"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginVertical="8dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/spinner_modules_card"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        app:strokeColor="@color/nh_box_stroke_spinner"
                        app:strokeWidth="2dp"
                        app:boxStrokeWidthFocused="3dp"
                        android:padding="4dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <Spinner
                            android:id="@+id/module_spinner"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:spinnerMode="dropdown"/>

                    </com.google.android.material.card.MaterialCardView>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="10dp"
                    tools:ignore="TooManyViews">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/spinner_submodules_card"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        app:strokeColor="@color/nh_box_stroke_spinner"
                        app:strokeWidth="2dp"
                        app:boxStrokeWidthFocused="3dp"
                        android:padding="4dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/start_button"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <Spinner
                            android:id="@+id/submodule_spinner"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:spinnerMode="dropdown" />

                    </com.google.android.material.card.MaterialCardView>

                    <Button
                        android:id="@+id/start_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/Run"
                        app:layout_constraintStart_toEndOf="@id/spinner_submodules_card"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:layout_marginStart="8dp" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</com.google.android.material.card.MaterialCardView>