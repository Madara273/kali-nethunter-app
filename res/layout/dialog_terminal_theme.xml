<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/label_theme"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/terminal_label_theme"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
        android:paddingBottom="8dp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chips_themes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:singleLine="true"
            android:paddingBottom="12dp" >

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_theme_0"
                style="@style/Widget.Material3.Chip.Filter.Elevated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_classic_dark" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_theme_1"
                style="@style/Widget.Material3.Chip.Filter.Elevated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_solarized_dark" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_theme_2"
                style="@style/Widget.Material3.Chip.Filter.Elevated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_solarized_light" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_theme_3"
                style="@style/Widget.Material3.Chip.Filter.Elevated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_dracula" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_theme_4"
                style="@style/Widget.Material3.Chip.Filter.Elevated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_one_dark" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_theme_5"
                style="@style/Widget.Material3.Chip.Filter.Elevated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_high_contrast" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_theme_6"
                style="@style/Widget.Material3.Chip.Filter.Elevated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_matrix" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_theme_7"
                style="@style/Widget.Material3.Chip.Filter.Elevated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_kali_linux" />
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/preview_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/preview_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/terminal_title_preview"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/preview_line1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/preview_line1_text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/preview_line2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preview_line2_text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/preview_line3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preview_line3_text"
                android:textSize="13sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/label_format"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/terminal_title_layout"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
        android:paddingBottom="8dp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chips_format"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:singleLine="true"
            android:paddingBottom="12dp" >

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_format_minimal"
                style="@style/Widget.Material3.Chip.Filter.Elevated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/format_minimal" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_format_compact"
                style="@style/Widget.Material3.Chip.Filter.Elevated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/format_compact" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_format_comfortable"
                style="@style/Widget.Material3.Chip.Filter.Elevated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/format_comfortable" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_format_large"
                style="@style/Widget.Material3.Chip.Filter.Elevated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/format_large" />
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reset"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/terminal_btn_reset" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/terminal_btn_cancel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_apply"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/terminal_btn_apply" />
    </LinearLayout>
</LinearLayout>