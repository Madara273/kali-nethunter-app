<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:id="@+id/terminal_content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <FrameLayout
            android:id="@+id/terminal_output_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/terminal_recycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never"
                android:scrollbars="vertical"
                android:background="@drawable/bg_card_tech"
                android:clipToPadding="false"
                android:paddingBottom="72dp" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_go_bottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="12dp"
                android:contentDescription="@string/terminal_button_goto_bottom"
                android:visibility="gone"
                app:srcCompat="@drawable/ic_arrow_downward"
                app:useCompatPadding="true"
                app:backgroundTint="@color/design_default_color_primary"
                app:tint="@android:color/white" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/key_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:weightSum="5">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tab"
                style="@style/Tech.Button.Primary.Compact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/terminal_button_tab"
                app:rippleColor="@color/system_tab_ripple" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_left"
                style="@style/Tech.Button.Primary.Compact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/terminal_button_arrow_left"
                app:rippleColor="@color/system_tab_ripple" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_right"
                style="@style/Tech.Button.Primary.Compact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/terminal_button_arrow_right"
                app:rippleColor="@color/system_tab_ripple" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_up"
                style="@style/Tech.Button.Primary.Compact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/terminal_button_arrow_up"
                app:rippleColor="@color/system_tab_ripple" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_down"
                style="@style/Tech.Button.Primary.Compact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/terminal_button_arrow_down"
                app:rippleColor="@color/system_tab_ripple" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/key_toolbar_ctrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ctrl"
                style="@style/Tech.Button.Primary.Compact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/terminal_button_ctrl"
                app:rippleColor="@color/system_tab_ripple" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/terminal_cmd_clear"
                style="@style/Tech.Button.Outlined.Compact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/terminal_button_clear"
                app:rippleColor="@color/system_tab_ripple" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/input_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/input_layout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:hint="@string/terminal_hint_enter_command"
                app:boxStrokeColor="?attr/colorPrimary"
                app:hintTextColor="?attr/colorOnSurfaceVariant"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_send"
                app:endIconContentDescription="@string/terminal_send_command_desc">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_edit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints=""
                    android:imeOptions="actionSend|flagNoFullscreen"
                    android:importantForAutofill="no"
                    android:inputType="textNoSuggestions|textVisiblePassword"
                    android:maxLines="1"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="monospace" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>